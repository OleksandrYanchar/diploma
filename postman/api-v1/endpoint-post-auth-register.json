{
  "method": "POST",
  "path": "/api/v1/auth/register",
  "authentication": "none",
  "contentType": "application/json",
  "scenarios": {
    "success_valid_password": {
      "description": "SR-01 compliant password: 12+ chars, upper, lower, digit, special.",
      "body": {
        "email": "new.user@example.com",
        "password": "Str0ng!Passw0rd"
      },
      "expectedStatus": 201
    },
    "conflict_email_already_registered": {
      "description": "Same email as an existing user → 409.",
      "body": {
        "email": "existing@example.com",
        "password": "Str0ng!Passw0rd"
      },
      "expectedStatus": 409
    },
    "validation_weak_password_service_422": {
      "description": "Meets schema min_length 12 but fails SR-01 (e.g. no special char) → 422 from service.",
      "body": {
        "email": "weak@example.com",
        "password": "WeakPassword12"
      },
      "expectedStatus": 422
    },
    "validation_password_too_short_schema_422": {
      "description": "Password under 12 characters → 422 from Pydantic.",
      "body": {
        "email": "short@example.com",
        "password": "Short1!"
      },
      "expectedStatus": 422
    },
    "validation_invalid_email_schema_422": {
      "description": "Invalid email format → 422.",
      "body": {
        "email": "not-an-email",
        "password": "Str0ng!Passw0rd"
      },
      "expectedStatus": 422
    }
  }
}
