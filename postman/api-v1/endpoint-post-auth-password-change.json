{
  "method": "POST",
  "path": "/api/v1/auth/password/change",
  "authentication": "Bearer (email verification not required)",
  "contentType": "application/json",
  "headers": {
    "Authorization": "Bearer {{access_token}}"
  },
  "scenarios": {
    "success": {
      "description": "current_password correct; new_password satisfies SR-01.",
      "body": {
        "current_password": "OldPassword1!",
        "new_password": "NewStr0ng!Pass"
      },
      "expectedStatus": 200
    },
    "failure_wrong_current_password_401": {
      "body": {
        "current_password": "WrongPassword1!",
        "new_password": "NewStr0ng!Pass"
      },
      "expectedStatus": 401
    },
    "failure_new_password_weak_422": {
      "description": "new_password min 12 in schema but fails SR-01 in service.",
      "body": {
        "current_password": "OldPassword1!",
        "new_password": "weakpassword12"
      },
      "expectedStatus": 422
    },
    "validation_new_password_too_short_schema_422": {
      "body": {
        "current_password": "OldPassword1!",
        "new_password": "short"
      },
      "expectedStatus": 422
    },
    "failure_missing_authorization_403": {
      "headers": {},
      "body": {
        "current_password": "OldPassword1!",
        "new_password": "NewStr0ng!Pass"
      },
      "expectedStatus": 403
    },
    "failure_invalid_token_401": {
      "headers": {
        "Authorization": "Bearer invalid.jwt.here"
      },
      "body": {
        "current_password": "OldPassword1!",
        "new_password": "NewStr0ng!Pass"
      },
      "expectedStatus": 401
    }
  }
}
