{
  "method": "GET",
  "path": "/api/v1/admin/users",
  "authentication": "Bearer + verified email + ADMIN role",
  "query_params": {
    "limit": "1–200, default 50",
    "offset": "≥ 0, default 0"
  },
  "headers": {
    "Authorization": "Bearer {{access_token_admin_verified}}"
  },
  "scenarios": {
    "success_admin_verified": {
      "headers": {
        "Authorization": "Bearer {{access_token_admin_verified}}"
      },
      "expectedStatus": 200,
      "description": "ADMIN role — returns list of users with security metadata."
    },
    "failure_auditor_forbidden_403": {
      "description": "AUDITOR role is not allowed to list users (SR-11).",
      "headers": {
        "Authorization": "Bearer {{access_token_auditor_verified}}"
      },
      "expectedStatus": 403
    },
    "failure_customer_forbidden_403": {
      "description": "USER role is not allowed to list users (SR-11).",
      "headers": {
        "Authorization": "Bearer {{access_token_customer_verified}}"
      },
      "expectedStatus": 403
    },
    "failure_missing_authorization_403": {
      "headers": {},
      "expectedStatus": 403
    }
  }
}
