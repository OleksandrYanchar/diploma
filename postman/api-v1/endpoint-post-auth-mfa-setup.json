{
  "method": "POST",
  "path": "/api/v1/auth/mfa/setup",
  "authentication": "Bearer + email verified (require_verified)",
  "contentType": "application/json",
  "headers": {
    "Authorization": "Bearer {{access_token_verified}}"
  },
  "scenarios": {
    "success_first_time_setup": {
      "description": "Verified user without active MFA; returns secret + qr_code_base64 once.",
      "headers": {
        "Authorization": "Bearer {{access_token_verified}}"
      },
      "body": null,
      "expectedStatus": 200
    },
    "failure_mfa_already_enabled_400": {
      "description": "User already has mfa_enabled.",
      "headers": {
        "Authorization": "Bearer {{access_token_mfa_enabled}}"
      },
      "body": null,
      "expectedStatus": 400
    },
    "failure_unverified_email_403": {
      "description": "require_verified blocks unverified users.",
      "headers": {
        "Authorization": "Bearer {{access_token_unverified}}"
      },
      "body": null,
      "expectedStatus": 403
    },
    "failure_missing_token_403": {
      "headers": {},
      "body": null,
      "expectedStatus": 403
    },
    "failure_invalid_token_401": {
      "headers": {
        "Authorization": "Bearer invalid.jwt.here"
      },
      "body": null,
      "expectedStatus": 401
    }
  }
}
