# .env.example — copy to .env and fill in real values before running.
# The .env file is listed in .gitignore and must NEVER be committed.
#
# Generate a strong JWT secret with:
#   python -c "import secrets; print(secrets.token_hex(32))"

# ------------------------------------------------------------------
# Application
# ------------------------------------------------------------------
DEBUG=false
ENVIRONMENT=development

# ------------------------------------------------------------------
# PostgreSQL
# ------------------------------------------------------------------
POSTGRES_USER=finapp
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=finapp_db
# POSTGRES_HOST and POSTGRES_PORT default to localhost:5432 when not set.
# DATABASE_URL is constructed automatically from the vars above.
# You only need to set DATABASE_URL directly if you are connecting to an
# external database that cannot be described by the component vars.

# ------------------------------------------------------------------
# Redis
# ------------------------------------------------------------------
REDIS_PASSWORD=change_me_redis_password
# REDIS_HOST and REDIS_PORT default to localhost:6379 when not set.
# REDIS_URL is constructed automatically from REDIS_PASSWORD above.

# ------------------------------------------------------------------
# JWT
# ------------------------------------------------------------------
# REQUIRED: generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=REPLACE_WITH_A_64_CHARACTER_RANDOM_HEX_STRING_DO_NOT_USE_THIS_VALUE
JWT_ALGORITHM=HS256

# ------------------------------------------------------------------
# Token lifetimes (optional — defaults match security requirements)
# ------------------------------------------------------------------
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
STEP_UP_TOKEN_EXPIRE_MINUTES=5

# ------------------------------------------------------------------
# Security policy
# ------------------------------------------------------------------
MAX_FAILED_LOGIN_ATTEMPTS=5
ACCOUNT_LOCKOUT_MINUTES=30

# Step-up threshold in smallest currency unit (cents).
# 100000 = 1000.00 USD
STEP_UP_TRANSFER_THRESHOLD=100000

# ------------------------------------------------------------------
# CORS
# ------------------------------------------------------------------
# Comma-separated list of allowed origins.  Lock to exact frontend URL in production.
ALLOWED_ORIGINS=http://localhost,http://localhost:3000
